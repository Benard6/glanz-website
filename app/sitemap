import type { MetadataRoute } from "next";

export default function sitemap(): MetadataRoute.Sitemap {
  const baseUrl = "https://www.glanzkenya.co.ke";

  const services = [
    "sofa-cleaning",
    "house-cleaning",
    "carpet-cleaning",
    "fumigation",
    "mattress-cleaning",
    "cabro-cleaning",
    "post-construction-cleaning",
    "window-cleaning",
  ];

  const towns = [
    "nairobi",
    "kiambu",
    "thika",
    "ruiru",
    "juja",
    "westlands",
    "kilimani",
    "kasarani",
    "kahawa-west",
    "zimmerman",
    "githurai",
  ];

  const urls: MetadataRoute.Sitemap = [];

  // base pages
  urls.push({
    url: baseUrl,
    lastModified: new Date(),
  });

  // service pages
  services.forEach((service) => {
    urls.push({
      url: `${baseUrl}/services/${service}`,
      lastModified: new Date(),
    });

    // 🔥 service × town pages
    towns.forEach((town) => {
      urls.push({
        url: `${baseUrl}/services/${service}/${town}`,
        lastModified: new Date(),
      });
    });
  });

  return urls;
}